// ── Notification Engine ───────────────────────────────────────────────────────
function useNotifications(assignments, courses) {
  const [permission, setPermission] = useState(typeof Notification !== "undefined" ? Notification.permission : "default");
  const [notifLog, setNotifLog] = useState([]); // for in-app bell display
  const timerRef = useRef(null);

  const requestPermission = async () => {
    if (typeof Notification === "undefined") return;
    const result = await Notification.requestPermission();
    setPermission(result);
    return result;
  };

  const fireNotification = (title, body, tag) => {
    if (permission !== "granted") return;
    try {
      new Notification(title, { body, tag, icon: "📚", badge: "📚" });
    } catch(e) {}
    setNotifLog(prev => {
      const exists = prev.find(n => n.tag === tag);
      if (exists) return prev;
      return [{ title, body, tag, time: new Date() }, ...prev].slice(0, 20);
    });
  };

  const checkAndFire = () => {
    if (permission !== "granted") return;
    const now = new Date();
    const todayStr = now.toISOString().slice(0, 10);
    const hour = now.getHours();

    assignments.forEach(a => {
      if (a.done) return;
      const due = new Date(a.due + "T00:00:00");
      const daysLeft = Math.ceil((due - now) / 86400000);
      const course = courses.find(c => String(c.id) === String(a.courseId));
      const courseLabel = course ? ` (${course.name})` : "";

      // Day-of at 7 AM
      if (a.due === todayStr && hour >= NOTIF_HOUR) {
        fireNotification(
          "📅 Due Today!",
          `"${a.title}"${courseLabel} is due today!`,
          `due-today-${a.id}-${todayStr}`
        );
      }
      // 1 day before at 7 AM
      if (daysLeft === 1 && hour >= NOTIF_HOUR) {
        fireNotification(
          "⚠️ Due Tomorrow",
          `"${a.title}"${courseLabel} is due tomorrow!`,
          `due-1day-${a.id}-${a.due}`
        );
      }
      // 3 days before at 7 AM
      if (daysLeft === 3 && hour >= NOTIF_HOUR) {
        fireNotification(
          "📌 Due in 3 Days",
          `"${a.title}"${courseLabel} is due in 3 days.`,
          `due-3day-${a.id}-${a.due}`
        );
      }
    });
  };

  useEffect(() => {
    if (permission !== "granted") return;
    checkAndFire();
    // Check every 30 minutes
    timerRef.current = setInterval(checkAndFire, 30 * 60 * 1000);
    return () => clearInterval(timerRef.current);
  }, [permission, assignments]);

  return { permission, requestPermission, notifLog, checkAndFire };
}

